{
  "entities": {
    "Subscriber": {
      "title": "Subscriber",
      "description": "A user who has subscribed to network health alerts.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the subscriber."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the subscription was created."
        }
      },
      "required": ["email", "createdAt"]
    },
    "TestResult": {
      "title": "TestResult",
      "description": "A speed test result.",
      "type": "object",
      "properties": {
        "download": { "type": "number" },
        "upload": { "type": "number" },
        "ping": { "type": "number" },
        "jitter": { "type": "number" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["download", "upload", "ping", "jitter", "timestamp"]
    }
  },
  "firestore": {
    "/subscribers/{subscriberId}": {
      "schema": "Subscriber",
      "description": "Collection of email subscribers."
    },
    "/tests/{testId}": {
      "schema": "TestResult",
      "description": "Collection of speed test results."
    }
  }
}
